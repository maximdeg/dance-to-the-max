# Postgres connection string. Locally this can be a plain Postgres instance.
# On Vercel, use a POOLED connection string (e.g. Neon's `-pooler` host) because
# serverless functions open many short-lived connections.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dance_to_the_max

# Secret used to sign the session cookie. Generate a strong random value in
# production (e.g. `openssl rand -hex 32`) and set it in the Vercel project.
SESSION_SECRET=dev-insecure-secret-change-me
